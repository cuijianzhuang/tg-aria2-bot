BOT_TOKEN=123456:ABC-xxx
API_ID=xxxxx
API_HASH=xxxxx
BOT_API_URL=http://telegram-bot-api:8081

ARIA2_RPC=http://aria2:6800/jsonrpc
ARIA2_SECRET=change_me_generate_with_openssl_rand_hex_16

ALLOWED_USER_IDS=111111,222222
# 管理员（重启服务/白名单管理/GoFile/rclone 开关）。留空时回退为
# ALLOWED_USER_IDS 里的用户；两者都为空（机器人完全开放）时管理功能锁定。
ADMIN_USER_IDS=
DOWNLOAD_DIR=/downloads
# 设置菜单"下载目录"切换器里的备选目录，逗号分隔（当前 DOWNLOAD_DIR 会自动排第一，
# 不用重复写）。留空则只有当前目录一个选项。
DOWNLOAD_DIR_PRESETS=
# 单文件大小上限（字节）。0 表示不限。设置菜单里可以直接切换，这里只是初始值。
MAX_FILE_SIZE=2147483648
MAX_CONCURRENT=3
# 下载完成/失败时是否补发新消息（进度卡片的原地编辑不受影响）。
# 设置菜单里可以直接切换，这里只是初始值。
NOTIFY_ON_COMPLETE=true
# 已完成任务记录自动清理，单位天，0 表示关闭。只删机器人里的记录，不删磁盘文件。
# 设置菜单里可以直接切换，这里只是初始值。
AUTO_CLEANUP_DAYS=0
# 下载完成后自动把文件发回 Telegram（≤2GB 的单文件才发，目录/超限自动跳过）。
# 设置菜单里可以直接切换，这里只是初始值。
AUTO_SEND_TO_TG=false
# 磁盘剩余空间低于该值（GiB）时主动私聊提醒管理员，0 表示关闭。
DISK_ALERT_THRESHOLD_GB=10
PROXY_URL=
DB_PATH=/app/data/tasks.db

# Web 管理后台 (bot/web)，留空则后台禁用
ADMIN_PASSWORD=
WEB_PORT=8080
# 仅当 web 后台挂在可信反向代理（nginx/caddy）后面时才设为 true，
# 否则 X-Forwarded-For 可被伪造用来绕过登录限流。
TRUST_PROXY_HEADERS=false
# web 容器里 aria2-config 的挂载路径，一般不用改
ARIA2_CONFIG_DIR=/aria2-config
# rclone 上传开关要改写的 aria2.conf 钩子路径。默认匹配 docker 模式下
# p3terx/aria2-pro 镜像的 /config/script/ 目录习惯；bare 模式必须改成
# aria2-bare/ 目录下 clean.sh / upload.sh 的实际绝对路径，否则钩子会指向
# 不存在的文件（同类问题之前在 docker 部署上出现过一次）。
ARIA2_CLEAN_HOOK=/config/script/clean.sh
ARIA2_UPLOAD_HOOK=/config/script/upload.sh

# GoFile 上传（下载完成后可选压缩+上传到 gofile.io+可选删除本地文件），
# 跑在 bot 进程自己里面（task_manager.py），不依赖 aria2 钩子。
# 改这几项要重启 bot 才生效（docker: docker compose restart bot；
# 裸机: systemctl restart tg-aria2-bot）。
GOFILE_ENABLED=false
GOFILE_TOKEN=
GOFILE_COMPRESS=true
GOFILE_DELETE_LOCAL=false
