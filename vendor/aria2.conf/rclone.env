#
# https://github.com/P3TERX/aria2.conf
# File name：rclone.env
# Description: RCLONE environment variables file
# Version: 2020.11.26 (verbatim upstream, MIT License)
#
# 仅在 upload.sh 被接入 on-download-complete 钩子时才会被读取（见 script.conf 顶部说明），
# 默认未启用。这里只是把上游模板放到位，方便 V3 阶段随时启用网盘上传。
#

#RCLONE_CONFIG=/config/rclone.conf
#RCLONE_CONFIG_PASS=
#RCLONE_BWLIMIT=10M
#RCLONE_TRANSFERS=4
#RCLONE_BUFFER_SIZE=16M
#RCLONE_RETRIES=3
RCLONE_RETRIES_SLEEP=10s
#RCLONE_IGNORE_ERRORS=true
#RCLONE_IGNORE_EXISTING=true
#RCLONE_PROGRESS=true
#HTTP_PROXY=localhost:1080
#HTTPS_PROXY=$HTTP_PROXY
